# ══════════════════════════════════════════════════════════════
#  DEFECT PREDICTOR — Environment Configuration
#  
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in values   (defaults work fine for local dev)
#    3. Never commit .env to Git (it is already in .gitignore)
# ══════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────
#  MLFLOW — Experiment Tracking
# ─────────────────────────────────────────────────────────────

# Where MLflow stores experiment runs
# Default: local folder called mlruns/ in project root
# Change to a remote server if you have one: http://your-server:5000
MLFLOW_TRACKING_URI=./mlruns

# Name that appears in the MLflow UI for this project
MLFLOW_EXPERIMENT_NAME=defect-prediction


# ─────────────────────────────────────────────────────────────
#  GITHUB — Optional, increases API rate limits
# ─────────────────────────────────────────────────────────────

# Without a token: 60 requests/hour (may be enough for small repos)
# With a token:    5000 requests/hour (recommended for large repos)
#
# How to get one:
#   GitHub → Settings → Developer settings → Personal access tokens
#   → Tokens (classic) → Generate new token
#   → Select scope: repo (read-only is fine)
#   
# Leave blank if you don't have one — mining will still work
GITHUB_TOKEN=


# ─────────────────────────────────────────────────────────────
#  MODEL — Paths and Settings
# ─────────────────────────────────────────────────────────────

# Where trained models are saved after training
MODEL_PATH=./models/best_xgb_model.pkl
GNN_MODEL_PATH=./models/gnn_model.pt
HYBRID_MODEL_PATH=./models/hybrid_model.pkl

# Random seed — keep this fixed for reproducibility
RANDOM_SEED=42


# ─────────────────────────────────────────────────────────────
#  FASTAPI — Backend Server
# ─────────────────────────────────────────────────────────────

# Host and port for the API server
# 0.0.0.0 means accessible from any network interface (local + LAN)
# Use 127.0.0.1 if you only want local access
API_HOST=0.0.0.0
API_PORT=8000

# Max repository size allowed for analysis (in MB)
# Repos larger than this are rejected to avoid OOM
MAX_REPO_SIZE_MB=500

# Timeout for the full analysis pipeline (seconds)
# Flask repo takes ~10 min, large repos may need more
ANALYSIS_TIMEOUT_SECONDS=600

# Number of background workers for parallel job processing
API_WORKERS=2


# ─────────────────────────────────────────────────────────────
#  DATA DIRECTORIES
# ─────────────────────────────────────────────────────────────

# These are relative to project root — change only if you want
# to store data outside the project folder (e.g. on a larger disk)
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
DATASETS_DIR=./data/datasets


# ─────────────────────────────────────────────────────────────
#  MINING — Git History Settings
# ─────────────────────────────────────────────────────────────

# How many years of git history to mine
# 5 years gives plenty of training data for most repos
MINING_YEARS_BACK=5

# Observation window size in days (for temporal feature computation)
# 90 days = look at the last 3 months before each prediction point
FEATURE_WINDOW_DAYS=90

# Prediction horizon in days (how far ahead we predict bugs)
# 90 days = predict whether a file will be buggy in the next 3 months
PREDICTION_HORIZON_DAYS=90


# ─────────────────────────────────────────────────────────────
#  GNN — Graph Neural Network Training
# ─────────────────────────────────────────────────────────────

# Set to 'cuda' if you have a GPU, 'cpu' otherwise
# The code auto-detects this but you can force it here
GNN_DEVICE=cuda

# GNN training epochs
# More epochs = better accuracy but slower training
# 100 is a good starting point
GNN_EPOCHS=100

# Batch size for GNN training
# Reduce if you run out of GPU memory
GNN_BATCH_SIZE=32


# ─────────────────────────────────────────────────────────────
#  LOGGING
# ─────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
# Use DEBUG during development, INFO for production
LOG_LEVEL=INFO

# Log file location (leave blank to only log to console)
LOG_FILE=./logs/defect_predictor.log


# ─────────────────────────────────────────────────────────────
#  STREAMLIT DASHBOARD
# ─────────────────────────────────────────────────────────────

# URL where the FastAPI backend is running
# Must match API_HOST and API_PORT above
BACKEND_URL=http://localhost:8000

# Dashboard page title
DASHBOARD_TITLE=Defect Prediction Engine
